        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;erDiagram\n    USERS ||--o{ RESERVATIONS : makes\n    USERS ||--o{ PAYMENTS : initiates\n    USERS ||--o{ REPORTS : submits\n    VENUES ||--o{ TICKETS : hosts\n    TICKETS ||--o{ SPORTS_DETAILS : has\n    TICKETS ||--o{ RESERVATIONS : included_in\n    TICKETS ||--o{ REPORTS : referenced_by\n    RESERVATIONS ||--|| PAYMENTS : generates\n    RESERVATIONS ||--o{ REPORTS : referenced_by\n\n    USERS {\n        int user_id PK\n        string full_name\n        string email\n        string phone_number\n        string password_hash\n        string role\n        string city\n        string status\n        timestamp created_at\n    }\n\n    VENUES {\n        int venue_id PK\n        string venue_name\n        string city\n        string province\n        int capacity\n    }\n\n    TICKETS {\n        int ticket_id PK\n        string sport_type\n        string home_team\n        string away_team\n        timestamp match_date\n        int venue_id FK\n        decimal base_price\n        int remaining_capacity\n        string seat_category\n    }\n\n    SPORTS_DETAILS {\n        int detail_id PK\n        int ticket_id FK\n        string tournament_name\n        string gate_number\n        string section_number\n        string row_number\n        string seat_number\n        text special_amenities\n    }\n\n    RESERVATIONS {\n        int reservation_id PK\n        int user_id FK\n        int ticket_id FK\n        string reservation_status\n        timestamp reserved_at\n        timestamp expires_at\n    }\n\n    PAYMENTS {\n        int payment_id PK\n        int user_id FK\n        int reservation_id FK\n        decimal amount\n        string payment_method\n        string payment_status\n        timestamp transaction_time\n    }\n\n    REPORTS {\n        int report_id PK\n        int user_id FK\n        int ticket_id FK\n        int reservation_id FK\n        string category\n        text report_text\n        string status\n        timestamp created_at\n    }&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="Vi6vs2b1gUV9lwFXaWtL-192">
